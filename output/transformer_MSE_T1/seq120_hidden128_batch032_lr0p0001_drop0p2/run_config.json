  "limit_basins": null,
  "train_basin_count": 30,
  "val_basin_count": 10,
  "test_basin_count": 10,
  "data_dir": null,
  "output_dir": "output/transformer_MSE_T1/seq120_hidden128_batch032_lr0p0001_drop0p2",
  "checkpoint": "output/transformer_MSE_T1/seq120_hidden128_batch032_lr0p0001_drop0p2/best_model.pt"
}