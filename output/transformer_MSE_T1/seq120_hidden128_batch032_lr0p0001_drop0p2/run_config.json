{
  "config": "configs/transformer_sweep.yaml",
  "model": "transformer",
  "seq_len": 120,
  "forecast_horizon": 1,
  "window_stride": 120,
  "dynamic_inputs": [
    "prcp",
    "tmax",
    "tmin",
    "srad",
    "vp"
  ],
  "target_variable": "qobs",
